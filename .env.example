# ── Google Sheets ─────────────────────────────────────────────────────
# ID da planilha Google Sheets usada para registrar e-mails.
# Encontre na URL: docs.google.com/spreadsheets/d/<SHEETS_ID>/edit
SHEETS_ID=

# ── E-mail IMAP/SMTP ──────────────────────────────────────────────────
COM4_EMAIL_ACCOUNT=atendimento@seudominio.com.br
COM4_EMAIL_PASSWORD=
COM4_EMAIL_IMAP_HOST=mail.seudominio.com.br
COM4_EMAIL_IMAP_PORT=993
COM4_EMAIL_SMTP_HOST=mail.seudominio.com.br
COM4_EMAIL_SMTP_PORT=587

# ── Relatório por e-mail ──────────────────────────────────────────────
# Lista de destinatários do relatório, separados por vírgula.
RELATORIO_DESTINATARIOS=gestao@seudominio.com.br,ti@seudominio.com.br

# ── WhatsApp (bridge Baileys local) ───────────────────────────────────
# JID do grupo no formato <numero>@g.us
WHATSAPP_GROUP_JID=
WHATSAPP_RECIPIENT=
WHATSAPP_BRIDGE_PORT=3000

# ── SLA ───────────────────────────────────────────────────────────────
SLA_HORAS=2
SLA_HORA_INICIO=8
SLA_HORA_FIM=18
SLA_REPEAT_HORAS=1
